@model LibraryPro1.Models.Student

<link rel="stylesheet" href="~/css/student.css" />

<div class="student-container">

    <div class="student-card">

        <h2>Add Student</h2>

        <form asp-action="Create" method="post">

            <div class="form-group">
                <input asp-for="Name" class="form-control" placeholder="Student Name">
            </div>

            <div class="form-group">
                <input asp-for="RollNumber" class="form-control" placeholder="Roll Number">
            </div>

            <div class="form-group">
                <input asp-for="Course" class="form-control" placeholder="Course">
            </div>

            <div class="form-group">
                <input asp-for="Semester" class="form-control" placeholder="Semester">
            </div>

            <div class="form-group">
                <input asp-for="Phone" class="form-control" placeholder="Phone Number">
            </div>

            <div class="form-group">
                <input asp-for="Email" class="form-control" placeholder="Email Address">
            </div>

            <button type="submit" class="btn-save">
                Save Student
            </button>

        </form>

    </div>

</div>