@model LibraryPro1.Models.Student

<h2>Edit Student</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="RollNumber"></label>
        <input asp-for="RollNumber" class="form-control" />
    </div>


    <div class="mb-3">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Phone"></label>
        <input asp-for="Phone" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Course</label>
        <input asp-for="Course" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Semester"></label>
        <input asp-for="Semester" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">
        Update Student
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>