@{
    ViewData["Title"] = "Forgot Password";
}

<h2>Forgot Password</h2>

<form method="post">
    <div class="mb-3">
        <label>Email</label>
        <input type="email" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">
        Reset Password
    </button>
</form>